# Terraform directories
.terraform/
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Sensitive variable files
*.tfvars
*.tfvars.json

# Override files (used for local testing)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan files
*.tfplan
*.plan

# CLI configuration files
.terraformrc
terraform.rc

# Local environment files
.env
.env.*

# Editor / OS files
.vscode/
.idea/
*.swp
*.bak
.DS_Store
Thumbs.db